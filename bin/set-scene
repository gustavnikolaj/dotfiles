#!/usr/bin/env bash

# Handle optional parameter
mode="${1:-default}"

case "$mode" in
    meeting-evening)
        # Evening call settings
        lights evening
        brightness dim
        ;;
    meeting)
        # Day call settings
        lights cloudy
        brightness bright
        ;;
    meeting-winter)
        # Day call settings
        lights cloudy-warm
        brightness 30
        ;;
    -h)
        echo "meeting"
        echo "meeting-evening"
        echo "default <or empty>"
        ;;
    default)
        # Not on call
        lights off
        brightness bright
        ;;
esac
